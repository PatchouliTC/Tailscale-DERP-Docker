# DERP server domain
TAILSCALE_DERP_HOSTNAME=derp.example.com
# do not change this unless you know what it does
TAILSCALE_DERP_VERIFY_CLIENTS=true
# client login server url [if you use headscale as your login server, set this to your headscale server url]
HEADSCALE_LOGIN_SERVER=https://your.headscale.server
# pre auth key for tailscale client auth [if you use headscale as your login server, set this to a preauth key generated by headscale]
TAILSCALE_AUTH_KEY="ENTER YOUR TAILSCALE AUTH KEY HERE"
# DERP client hostname [displayed in the tailscale client list and used for naming the container and network]
TAILSCALE_HOSTNAME="derp-client"
DERP_ADDR="443" # DERP server listen address
DERP_STUN_PORT=3478 # DERP STUN port
DERP_HTTP_PORT=80 # DERP HTTP port (used for ACME challenges if using Let's Encrypt)
# verify mode [if you use derp to get certificates,otherwise set "manual"]
TAILSCALE_DERP_CERTMODE=letsencrypt